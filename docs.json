{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Protoface",
  "colors": {
    "primary": "#0c0d0e",
    "light": "#fcfbfa",
    "dark": "#0c0d0e"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "logo": {
    "light": "/images/brand/protoface-logo-light.png",
    "dark": "/images/brand/protoface-logo-dark.png",
    "href": "https://protoface.com"
  },
  "favicon": {
    "light": "/images/brand/protoface-mark-ink.png",
    "dark": "/images/brand/protoface-mark-white.png"
  },
  "icons": {
    "library": "lucide"
  },
  "contextual": {
    "display": "header",
    "options": [
      "copy",
      "chatgpt",
      "claude",
      "cursor",
      "vscode",
      "download-spec"
    ]
  },
  "api": {
    "openapi": "openapi.json",
    "playground": {
      "display": "none"
    },
    "url": "full",
    "examples": {
      "languages": ["curl", "python", "javascript"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Platform",
          "icon": "layout-dashboard",
          "href": "https://app.protoface.com"
        },
        {
          "anchor": "Examples",
          "icon": "github",
          "href": "https://github.com/protoface-ai/protoface-quickstart"
        },
        {
          "anchor": "Support",
          "icon": "life-buoy",
          "href": "https://protoface.discourse.group/"
        },
        {
          "anchor": "Status",
          "icon": "activity",
          "href": "https://status.protoface.com"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Docs",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Integrations",
            "pages": [
              "guides/livekit-agents",
              "guides/pipecat",
              "guides/more-integrations"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/avatars",
              "guides/usage",
              "guides/avatar-source-images"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/errors",
              "reference/quotas",
              "reference/known-issues"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "API Reference",
            "root": "api-reference/index",
            "openapi": "openapi.json",
            "pages": [
              "GET /v1/avatars",
              "POST /v1/avatars",
              "GET /v1/avatars/{avatar_id}",
              "DELETE /v1/avatars/{avatar_id}",
              "GET /v1/billing/plans",
              "GET /v1/sessions",
              "POST /v1/sessions",
              "GET /v1/sessions/{session_id}",
              "POST /v1/sessions/{session_id}/end",
              "GET /v1/status",
              "GET /v1/usage"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/guides/sessions",
      "destination": "/guides/livekit-agents"
    },
    {
      "source": "/concepts/transports",
      "destination": "/guides/livekit-agents"
    },
    {
      "source": "/concepts/architecture",
      "destination": "/"
    },
    {
      "source": "/reference/limits",
      "destination": "/reference/quotas"
    },
    {
      "source": "/reference/known-limitations",
      "destination": "/reference/known-issues"
    }
  ]
}
